---
/* src/layouts/Biolinks.astro */
import '../styles/global.css';

interface Props {
    title?: string;
    description?: string;
    image?: string; // Recibirá el "avatar" del archivo .md
}

const { 
    title = "Enlace Inteligente", 
    description = "Accede a nuestros enlaces oficiales, lanzamientos y contenido exclusivo en un solo lugar.",
    image = "/assets/images/icon.svg" // Icono genérico por defecto
} = Astro.props;

// Añadimos tu firma dinámica al título
const signedTitle = `${title} | Powered by yaga.haus`;

// Forzamos rutas absolutas para que no falle la vista previa en celulares
const socialImageURL = new URL(image, Astro.site || 'https://yaga.haus').href;
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://yaga.haus').href;
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" type="image/x-icon" href="/favicon.ico" />
        <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
        <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
        <meta name="generator" content={Astro.generator} />

        <title>{signedTitle}</title>
        <meta name="description" content={description} />
        <meta name="keywords" content="smart links,enlace inteligente,presave,link in bio,yagahaus" />
        <meta name="author" content="yagahaus" />
        <link rel="canonical" href={canonicalURL} />

        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={signedTitle} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={socialImageURL} /> <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={canonicalURL} />
        <meta property="twitter:title" content={signedTitle} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={socialImageURL} />

        <style>
            html, body {
                margin: 0;
                padding: 0;
                width: 100%;
                max-width: 100vw;
                overflow-x: hidden;
                box-sizing: border-box;
            }
            *, *::before, *::after {
                box-sizing: inherit;
            }
        </style>
    </head>
    
    <body style="display: flex; flex-direction: column; min-height: 100vh;">
        <main style="flex: 1; display: flex; flex-direction: column; width: 100%;">
            <slot />
        </main>
    </body>
</html>