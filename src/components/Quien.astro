/* === OPTIMIZACIÓN PARA MÓVILES (COLAPSADO) === */
  @media (max-width: 850px) {
    .quien-container {
      flex-direction: column;
      min-height: auto; 
    }
    
    .quien-media-col {
      width: 100%;
      height: 50vh; 
      padding: 0; 
      overflow: hidden; 
    }

    .lottie-desktop {
      display: none !important;
    }

    .image-mobile {
      display: block;
      width: 100%;
      height: 100%;
    }

    .quien-text-col {
      width: 100%;
      padding: 3rem 2rem 5rem 2rem; 
      align-items: center; /* Mantiene el botón centrado */
      text-align: center; /* Centra el título por defecto */
    }

    /* EL AJUSTE DE LECTURA: Párrafo a la izquierda */
    .quien-text-col p {
      text-align: left;
      width: 100%; /* Asegura que tome todo el ancho para justificar bien */
    }

    .quien-text-col h2 br {
      display: none; 
    }

    .btn-primary-dark {
      align-self: center; 
      text-align: center;
      width: 100%;
      max-width: 280px; 
    }
  }