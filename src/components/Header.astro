---
/* src/components/Header.astro */
import nav from '../data/nav.json';
import settings from '../data/settings.json';

const enlaces = nav?.enlaces || [];
const botones = nav?.botones || [];
const redes = settings?.redes || [];

// Detectar página activa
const pathname = Astro.url.pathname;

// SOPORTE TOTAL PARA LAS 7 REDES SOCIALES DEL FORMULARIO
const getSocialSvg = (platform: string) => {
  const p = platform.toLowerCase();
  if (p.includes('facebook')) return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>';
  if (p.includes('instagram')) return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>';
  if (p.includes('tiktok')) return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>';
  if (p.includes('spotify')) return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 11.5c2.5-1 5.5-1 8 0"/><path d="M9 14c2-.7 4-.7 6 0"/><path d="M7 9c3.5-1.5 6.5-1.5 10 0"/></svg>';
  if (p.includes('linkedin')) return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>';
  if (p.includes('x') || p.includes('twitter')) return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 4l11.733 16h4.267l-11.733 -16z"/><path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772"/></svg>';
  if (p.includes('youtube')) return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="15" x="2" y="4.5" rx="4" ry="4"/><polygon points="10 9 15 12 10 15 10 9"/></svg>';
  return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>';
};
---

<div class="header-wrapper">
  
  <header class="nav-capsule">
    
    <div class="nav-desktop-only">
      <a href="/" style="display: flex; align-items: center;">
        <img src="/assets/logo/logo.svg" alt={settings.title} style="height: 28px; width: auto;" />
      </a>

      <nav style="display: flex; gap: 1.5rem; align-items: center;">
        {enlaces.map((enlace) => {
          const isActive = pathname === enlace.url || (pathname.startsWith(enlace.url) && enlace.url !== '/');
          return (
            <a href={enlace.url} class={`nav-link ${isActive ? 'active' : ''}`}>
              {enlace.texto}
            </a>
          );
        })}
      </nav>

      <div style="display: flex; gap: 1rem; align-items: center;">
        {botones.map((boton) => (
          <a href={boton.url} class="btn-principal">
            <span>{boton.texto}</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        ))}
      </div>

      <div style="display: flex; gap: 0.75rem; align-items: center; padding-right: 1rem; padding-left: 0.5rem;">
        {redes.map((red: any) => (
          <a href={red.url} target="_blank" rel="noopener noreferrer" class="social-nav-link" aria-label={red.red} set:html={getSocialSvg(red.red)} />
        ))}
      </div>
    </div>

    <div class="nav-mobile-only" style="gap: 0.5rem;">
      <button class="hamburger-btn menu-toggle" aria-label="Abrir Menú">
        <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>

      <button class="menu-toggle" style="background:none; border:none; cursor:pointer; display: flex; align-items: center;" aria-label="Abrir Menú">
        <img src="/assets/logo/logo.svg" alt={settings.title} style="height: 24px; width: auto;" />
      </button>
    </div>

  </header>
</div>

<div id="mobileMenu" class="mobile-menu-modal">
  <div class="mobile-menu-content">
    
    <button class="close-menu-btn menu-toggle" aria-label="Cerrar Menú">
      <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    <nav class="mobile-nav-links">
      {enlaces.map((enlace) => (
        <a href={enlace.url} class="nav-link menu-toggle-link" style="font-size: 1.25rem;">{enlace.texto}</a>
      ))}
    </nav>

    <div class="mobile-nav-buttons">
      {botones.map((boton) => (
        <a href={boton.url} class="btn-principal menu-toggle-link">
          <span>{boton.texto}</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      ))}
    </div>

    <div class="mobile-nav-socials">
      {redes.map((red: any) => (
        <a href={red.url} target="_blank" rel="noopener noreferrer" class="social-nav-link" set:html={getSocialSvg(red.red)} />
      ))}
    </div>

  </div>
</div>

<script>
  const toggles = document.querySelectorAll('.menu-toggle');
  const links = document.querySelectorAll('.menu-toggle-link');
  const modal = document.getElementById('mobileMenu');

  toggles.forEach(toggle => {
    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      modal?.classList.toggle('open');
      document.body.style.overflow = modal?.classList.contains('open') ? 'hidden' : '';
    });
  });

  links.forEach(link => {
    link.addEventListener('click', () => {
      modal?.classList.remove('open');
      document.body.style.overflow = '';
    });
  });

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) {
      modal.classList.remove('open');
      document.body.style.overflow = '';
    }
  });
</script>

<style>
  .header-wrapper {
    width: 100%; display: flex; justify-content: center; position: sticky; top: 1.5rem; z-index: 100; padding: 0 1.5rem;
  }
  
  .nav-desktop-only { display: flex; align-items: center; gap: 2rem; }
  .nav-mobile-only { display: none; align-items: center; }
  
  .hamburger-btn {
    background: none; border: none; color: var(--titulos-default-color, #000); cursor: pointer; display: flex; align-items: center;
  }

  .mobile-menu-modal {
    position: fixed; top: 0; left: 0; width: 100%; height: 100vh;
    background: rgba(0,0,0,0.5); z-index: 1000;
    opacity: 0; pointer-events: none; transition: opacity 0.3s ease;
    display: flex; justify-content: center; align-items: center; padding: 1.5rem;
  }
  .mobile-menu-modal.open { opacity: 1; pointer-events: auto; }

  .mobile-menu-content {
    background-color: var(--default-color, #fff); border-radius: var(--radius-card, 24px);
    padding: 3rem 2rem; width: 100%; max-width: 380px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.5);
    position: relative; transform: translateY(20px); transition: transform 0.3s ease;
    display: flex; flex-direction: column; gap: 2rem; 
    align-items: center; text-align: center;
  }
  .mobile-menu-modal.open .mobile-menu-content { transform: translateY(0); }

  .close-menu-btn {
    position: absolute; top: 1.5rem; right: 1.5rem; background: none; border: none;
    color: var(--texto-default-color, #000); cursor: pointer;
  }

  .mobile-nav-links { display: flex; flex-direction: column; gap: 1.2rem; align-items: center; }
  .mobile-nav-buttons { display: flex; flex-direction: column; gap: 0.8rem; align-items: center; }
  .mobile-nav-socials { display: flex; justify-content: center; gap: 1.5rem; padding-top: 1.5rem; border-top: 1px solid rgba(0,0,0,0.1); width: 100%; }

  /* === RESPONSIVE === */
  @media (max-width: 900px) {
    .nav-desktop-only { display: none !important; }
    .nav-mobile-only { display: flex !important; }
    
    .header-wrapper { justify-content: flex-start !important; }
    
    :global(.nav-capsule) { 
      width: max-content !important;
      padding: 0.5rem 1rem !important; 
    }
  }
</style>