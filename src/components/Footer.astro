---
/* src/components/Footer.astro */
import settings from '../data/settings.json';

const { title, address, email, telefonos = [] } = settings;
const currentYear = new Date().getFullYear();

// Mapeador estricto e infalible de vectores SVG según el tipo de contacto del CMS
const getContactIcon = (tipo: string) => {
  const t = tipo.toLowerCase();
  if (t === 'whatsapp') {
    return `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.38 0 0 1 8 8v.5z"/></svg>`;
  }
  if (t === 'telegram') {
    return `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" x2="11" y1="2" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>`;
  }
  // Teléfono clásico (Llamada)
  return `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.79 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>`;
};
---

<footer class="fondo-acento" style="padding: 4rem 2rem 2.5rem; display: flex; flex-direction: column; align-items: center; gap: 2rem; width: 100%;">
  
  {address && (
    <div style="display: flex; align-items: center; justify-content: center; gap: 0.6rem; text-align: center; font-size: 0.95rem; max-width: 600px; font-weight: 500;">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
        <circle cx="12" cy="10" r="3"></circle>
      </svg>
      <span>{address}</span>
    </div>
  )}

  <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; width: 100%;">
    
    {email && (
      <a href={`mailto:${email}`} class="btn-outline">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
        <span>{email}</span>
      </a>
    )}

    {telefonos.map((tel: any) => {
      let link = `tel:${tel.numero}`;
      if (tel.tipo === 'WhatsApp') link = `https://wa.me/${tel.numero.replace(/\D/g, '')}`;
      if (tel.tipo === 'Telegram') link = `https://t.me/${tel.numero.replace(/\D/g, '')}`;

      return (
        <a href={link} target="_blank" rel="noopener noreferrer" class="btn-outline">
          <span style="display: flex; align-items: center;" set:html={getContactIcon(tel.tipo)} />
          <span>{tel.nombre}</span>
        </a>
      );
    })}

  </div>

  <hr style="width: 100%; max-width: 850px; border: none; border-top: 1px solid rgba(255, 255, 255, 0.15); margin: 0.5rem 0 0;" />

  <div style="font-size: 0.85rem; opacity: 0.8; font-weight: 500; letter-spacing: 0.02em;">
    &copy; {currentYear} {title}
  </div>

</footer>