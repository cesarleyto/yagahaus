---
/* src/components/Hero.astro */
---

<section class="hero-container">
  <!-- Columna Izquierda: Textos y Conversión -->
  <div class="hero-left">
    <div class="hero-content">
      <h1 class="hero-title">
        Posicionamiento<br />digital para
      </h1>
      
      <!-- La Banda Infinita (Ticker) con inclinación -->
      <div class="ticker-wrapper">
        <div class="ticker-track">
          <!-- Conceptos Originales -->
          <div class="ticker-item">marcas personales</div>
          <div class="ticker-item">figuras públicas</div>
          <div class="ticker-item">artistas</div>
          <div class="ticker-item">profesionistas</div>
          <!-- Clones para el loop infinito -->
          <div class="ticker-item">marcas personales</div>
          <div class="ticker-item">figuras públicas</div>
          <div class="ticker-item">artistas</div>
          <div class="ticker-item">profesionistas</div>
        </div>
      </div>

      <div class="hero-bottom">
        <p class="hero-description">
          Los algoritmos de hoy penalizan el contenido sin estrategia y con falta de optimización. Necesitas posicionamiento real y una infraestructura diseñada para convertir clics en ventas y/o audiencias leales.
        </p>
        <a href="/contacto" class="btn-primary">
          Solicita una Auditoría
        </a>
      </div>
    </div><br /><br />
  </div>

  <!-- Columna Derecha: Imágenes Dinámicas -->
  <div class="hero-right">
    <div class="image-fade-wrapper">
      <img src="/assets/images/1.jpeg" alt="Profesionistas" class="hero-img active" id="img-1" />
      <img src="/assets/images/2.jpeg" alt="Figuras Públicas" class="hero-img" id="img-2" />
      <img src="/assets/images/3.jpeg" alt="Artistas" class="hero-img" id="img-3" />
    </div>
  </div>
</section>

<style>
  /* --- ESTILOS BASE / DESKTOP --- */
  .hero-container {
    display: flex;
    width: 100%;
    min-height: calc(100vh - 120px);
    align-items: center;
    overflow: hidden;
    position: relative;
  }

  .hero-left {
    width: 45%;
    padding-left: 5%;
    padding-right: 2rem;
    position: relative;
    z-index: 10;
  }

  .hero-title {
    font-size: 3.5rem;
    font-weight: 700; /* Letra con más cuerpo y ponche */
    line-height: 1.1;
    margin-bottom: 2rem;
    color: #FFFFFF; /* Blanco puro */
  }

  /* --- BANDA INFINITA (TICKER) --- */
  .ticker-wrapper {
    width: 150%;
    margin-left: -5%;
    overflow: hidden;
    transform: rotate(-3deg);
    mask-image: linear-gradient(to right, transparent 0%, black 20%, black 60%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 20%, black 60%, transparent 100%);
  }

  .ticker-track {
    display: inline-block;
    white-space: nowrap;
    animation: scrollTicker 12s linear infinite; 
  }

  .ticker-item {
    display: inline-block;
    font-size: 4rem;
    font-weight: 800;
    color: var(--color-fresa);
    text-transform: uppercase;
    padding-right: 3rem;
  }

  @keyframes scrollTicker {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .hero-bottom {
    margin-top: 3rem;
  }

  .hero-description {
    font-size: 1.1rem;
    font-weight: 300;
    color: #cccccc;
    margin-bottom: 2rem;
    max-width: 90%;
    line-height: 1.6;
  }

  .btn-primary {
    display: inline-block;
    background-color: var(--color-accent);
    color: var(--color-bg);
    padding: 15px 30px;
    border-radius: 99px;
    text-decoration: none;
    font-weight: 600;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(0, 255, 153, 0.2);
  }

  /* --- SECCIÓN IMÁGENES DESKTOP --- */
  .hero-right {
    width: 55%;
    height: 100vh;
    position: absolute;
    right: 0;
    top: 0;
    z-index: 1;
  }

  .image-fade-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    mask-image: linear-gradient(to left, black 60%, transparent 100%), linear-gradient(to top, black 80%, transparent 100%);
    -webkit-mask-image: linear-gradient(to left, black 60%, transparent 100%), linear-gradient(to top, black 80%, transparent 100%);
    mask-composite: intersect;
    -webkit-mask-composite: source-in;
  }

  .hero-img {
    position: absolute;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 1.5s ease-in-out;
  }

  .hero-img.active {
    opacity: 0.4;
  }

  /* --- 📱 CORRECCIÓN ULTRA-RESPONSIVA (MÓVIL) --- */
  @media (max-width: 850px) {
    .hero-container {
      flex-direction: column;
      justify-content: flex-start;
      min-height: auto;
      padding-bottom: 4rem;
    }

    /* 1. Forzamos que las imágenes vayan arriba en la estructura visual */
    .hero-right {
      order: 1;
      position: relative;
      width: 100%;
      height: 40vh; /* Altura controlada y segura para pantallas móviles */
    }

    /* Redefinimos el fundido: Ahora se desvanece de abajo hacia arriba */
    .image-fade-wrapper {
      mask-image: linear-gradient(to bottom, black 65%, transparent 100%);
      -webkit-mask-image: linear-gradient(to bottom, black 65%, transparent 100%);
      mask-composite: initial;
      -webkit-mask-composite: initial;
    }

    /* 2. El bloque de textos va abajo de manera natural */
    .hero-left {
      order: 2;
      width: 100%;
      padding: 2rem 24px 0 24px;
      box-sizing: border-box;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .hero-title {
      font-size: 2.2rem;
      margin-bottom: 1.5rem;
    }

    /* Ajuste de la banda para que no rompa el contenedor móvil */
    .ticker-wrapper {
      width: 100vw;
      margin-left: 0;
      mask-image: linear-gradient(to right, transparent 0%, black 15%, black 85%, transparent 100%);
      -webkit-mask-image: linear-gradient(to right, transparent 0%, black 15%, black 85%, transparent 100%);
    }

    .ticker-item {
      font-size: 2.3rem;
      padding-right: 1.5rem;
    }

    .hero-bottom {
      margin-top: 2rem;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .hero-description {
      font-size: 1rem;
      max-width: 100%;
      margin-bottom: 2rem;
    }

    .btn-primary {
      width: 100%;
      max-width: 340px; /* Tamaño de botón cómodo y legible para pulgares */
      padding: 16px 20px;
      font-size: 0.95rem;
    }
  }
</style>

<script>
  const totalImages = 3;
  let currentIndex = 1;

  setInterval(() => {
    const currentImg = document.getElementById(`img-${currentIndex}`);
    if (currentImg) currentImg.classList.remove('active');

    currentIndex = currentIndex === totalImages ? 1 : currentIndex + 1;

    const nextImg = document.getElementById(`img-${currentIndex}`);
    if (nextImg) nextImg.classList.add('active');
  }, 3000);
</script>