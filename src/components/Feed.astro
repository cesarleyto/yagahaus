---
/* src/components/Feed.astro */
import { getCollection } from 'astro:content';

// Obtener posts, ordenar por fecha y tomar solo los últimos 3
const posts = await getCollection('blog');
const latestPosts = posts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<section class="feed-container">
  <div class="feed-header">
    <h2 class="section-title">Aprende más en <span class="highlight">nuestro blog.</span></h2>
  </div>

  <div class="blog-grid">
    {latestPosts.map((post) => (
      <a href={`/blog/${post.id}`} class="blog-card" data-category={post.data.category}>
        <div class="card-image-wrapper">
          {post.data.image ? (
            <img src={post.data.image} alt={post.data.title} class="card-img" />
          ) : (
            <div class="img-placeholder"></div>
          )}
          {post.data.category && (
            <span class="category-badge">{post.data.category}</span>
          )}
        </div>
        
        <div class="card-content">
          <h3>{post.data.title}</h3>
          <p>{post.data.description}</p>
          <span class="link-more">Leer artículo &rarr;</span>
        </div>
      </a>
    ))}
  </div>

  <div class="btn-wrapper">
    <a href="/blog" class="btn-secondary">Ver todos los artículos</a>
  </div>
</section>

<style>
  :root { --color-fresa: #E91E63; }

  .feed-container {
    background-color: var(--color-bg);
    padding: 6rem 5%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .feed-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-title {
    font-size: 3rem;
    font-weight: 300;
    color: var(--color-text);
    margin: 0 0 0.5rem 0;
  }

  .highlight {
    font-weight: 800;
    color: var(--color-accent);
  }

  .feed-subtitle {
    font-size: 1.1rem;
    color: #888;
    margin: 0;
  }

  /* REUTILIZAMOS LOS ESTILOS EXACTOS DE LA TARJETA DEL BLOG */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    width: 100%;
    max-width: 1200px;
    margin-bottom: 3rem;
  }

  .blog-card {
    background-color: var(--color-bg);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 30px;
    padding: 1.5rem;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    transition: all 0.3s ease;
  }

  .blog-card:hover {
    transform: translateY(-5px);
    border-color: var(--color-accent);
    box-shadow: 0 15px 40px rgba(0, 255, 153, 0.15);
  }

  .card-image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 15px;
    overflow: hidden;
    background-color: rgba(255, 255, 255, 0.05);
  }

  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .blog-card:hover .card-img { transform: scale(1.05); }

  .img-placeholder {
    width: 100%; height: 100%;
    background-color: rgba(255, 255, 255, 0.05);
  }

  .category-badge {
    position: absolute;
    top: 15px; left: 15px;
    background-color: var(--color-fresa);
    color: #fff;
    padding: 6px 14px;
    border-radius: 99px;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    z-index: 2;
  }

  .card-content {
    display: flex; flex-direction: column; flex-grow: 1;
  }

  .card-content h3 {
    color: var(--color-text);
    font-size: 1.4rem; font-weight: 700;
    margin: 0 0 1rem 0; line-height: 1.3;
    transition: color 0.3s ease;
  }

  .blog-card:hover .card-content h3 { color: var(--color-accent); }

  .card-content p {
    color: #888888;
    font-size: 0.95rem; font-weight: 300;
    line-height: 1.6; margin: 0 0 1.5rem 0;
    flex-grow: 1;
  }

  .link-more {
    align-self: flex-start;
    color: var(--color-accent);
    font-weight: 700; font-size: 1rem;
    border-bottom: 1px solid transparent;
    transition: all 0.3s ease;
  }

  .blog-card:hover .link-more { border-bottom-color: var(--color-accent); }

  .btn-wrapper { margin-top: 2rem; }

  .btn-secondary {
    background: transparent;
    color: var(--color-text);
    padding: 14px 32px;
    border-radius: 99px;
    border: 1px solid rgba(255,255,255,0.2);
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .btn-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  @media (max-width: 1024px) {
    .blog-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 650px) {
    .blog-grid { grid-template-columns: 1fr; }
  }
</style>