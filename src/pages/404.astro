---
// Si tienes un Layout principal, puedes importarlo aquí
// import Layout from '../layouts/Layout.astro';
---

<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Error 404 | Yagahaus</title>
  
  <!-- ¡Aquí está la magia de la redirección! 
       5 = los segundos a esperar
       url=/ = hacia dónde lo va a mandar (la raíz) -->
  <meta http-equiv="refresh" content="5;url=/" />
  
  <style>
    /* Estilos súper básicos por si no usas Tailwind */
    body {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100vh;
      background-color: #000; /* Fondo oscuro tipo ingeniería */
      color: #fff;
      font-family: system-ui, sans-serif;
      text-align: center;
      margin: 0;
    }
    h1 {
      font-size: 4rem;
      margin-bottom: 0.5rem;
    }
    p {
      font-size: 1.2rem;
      color: #a1a1aa; /* Gris claro */
    }
  </style>
</head>
<body>
  
  <h1>Error 404</h1>
  <p>Página no encontrada, serás redireccionado a la página principal en unos segundos...</p>

  <!-- Opcional: Un botón por si el usuario es impaciente -->
  <a href="/" style="margin-top: 2rem; color: #ff0055; text-decoration: none;">
    Volver ahora
  </a>

</body>
</html>