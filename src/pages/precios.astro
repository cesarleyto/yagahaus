---
/* src/pages/precios.astro */
import Layout from '../layouts/Layout.astro';
import Porque from '../components/Porque.astro';
---

<Layout title="Precios y Planes | yagahaus">
  
  <section class="precios-container">
    
    <!-- CABECERA -->
    <header class="precios-header">
      <h1 class="page-title">Planes a la <span class="highlight-bold">medida.</span></h1>
      <p class="page-subtitle">Suscripciones mensuales diseñadas para crecer contigo. Todo el poder de nuestra infraestructura, mantenimiento y dirección creativa, trabajando en automático para tu carrera.</p>
    </header>

    <!-- HILERA DE SERVICIOS BASE -->
    <div class="servicios-base-wrapper">
      <h3 class="base-title">Todos nuestros planes incluyen tu infraestructura base:</h3>
      <div class="servicios-row">
        <div class="base-item"><img src="/assets/images/s1.svg" alt="Ecosistema Web" class="base-icon" /><span>Ecosistema Web</span></div>
        <div class="base-item"><img src="/assets/images/s2.svg" alt="Homogeneización SEO" class="base-icon" /><span>Homogeneización SEO</span></div>
        <div class="base-item"><img src="/assets/images/s4.svg" alt="Dominio Propio" class="base-icon" /><span>Dominio Propio</span></div>
        <div class="base-item"><img src="/assets/images/s5.svg" alt="Contenidos" class="base-icon" /><span>Contenidos</span></div>
        <div class="base-item"><img src="/assets/images/s6.svg" alt="Soporte Técnico" class="base-icon" /><span>Soporte Técnico</span></div>
      </div>
    </div>

    <!-- ESTRUCTURA FLEXIBLE -->
    <div class="pricing-layout">
      
      <!-- GRUPO 1: PAQUETE INICIAL -->
      <div class="pricing-group-single">
        <div class="grid-header">
          <h3 class="category-title">Paquete Inicial</h3>
          <p class="category-desc">No cuento con sitio web.</p>
        </div>
        <div class="pricing-card">
          <div class="card-header">
            <h2 class="plan-name">Básico</h2>
            <div class="plan-price-box">
              <div class="current-price">$5,000 <span class="price-period">inicial</span></div>
              <div class="plus-price">+ $600 <span class="price-period">anualidad</span></div>
            </div>
          </div>
          <div class="card-body">
            <ul class="benefits-list">
              <li><strong>Sitio web y dominio incluido</strong> + hosting. <span class="tooltip-icon">?<span class="tooltip-text">Incluye hosting premium y un dominio clásico (.com, .net, .org, etc).</span></span></li>
              <li><strong>Paquete inicial de contenidos estáticos.</strong> <span class="tooltip-icon">?<span class="tooltip-text">Diseñamos contenido para que arranques tu posicionamiento. Si no quieres continuar creando contenido, este paquete funcionará como contenido estático (hasta 8 piezas máx.).</span></span>
                <div class="format-icons fresa-icons">
                  <span class="f-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"></polygon><rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect></svg></span>
                  <span class="f-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg></span>
                  <span class="f-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"></path><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg></span>
                </div>
              </li>
              <li>Homogeneización SEO. <span class="tooltip-icon">?<span class="tooltip-text">Sincronización de tu información base en motores de búsqueda.</span></span></li>
              <li>Soporte técnico y modificaciones simples. <span class="tooltip-icon">?<span class="tooltip-text">Mantenimiento general del sitio y resolución de fallos.</span></span></li>
            </ul>
          </div>
        </div>
      </div>

      <!-- GRUPO 2: SUSCRIPCIONES -->
      <div class="pricing-group-double">
        <div class="grid-header">
          <h3 class="category-title" style="color: var(--color-accent);">Planes de Suscripción</h3>
          <p class="category-desc">Ya tengo sitio web y busco escalar mis contenidos.</p>
        </div>
        <div class="cards-row">
          <!-- CREADOR -->
          <div class="pricing-card featured">
            <div class="featured-badge">Más Elegido</div>
            <div class="card-header">
              <h2 class="plan-name">Creador</h2>
              <div class="plan-price-box">
                <div class="current-price">$4,000 <span class="price-period">/ mes</span></div>
                <div class="plus-price">Anualidad gratis <span class="tooltip-icon">?<span class="tooltip-text">Es gratis mientras sigas suscrito al plan Creador o Creador Plus.</span></span></div>
              </div>
            </div>
            <div class="card-body">
              <ul class="benefits-list">
                <li><strong>Todo lo del plan Básico, más:</strong></li>
                <li>Dirección creativa y postproducción de <strong>5 piezas</strong> multiformato. <span class="tooltip-icon">?<span class="tooltip-text">Nos encargamos de editar, pulir y estructurar tu material en crudo para máximo impacto.</span></span>
                  <div class="format-icons fresa-icons">
                    <span class="f-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"></polygon><rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect></svg></span>
                    <span class="f-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg></span>
                    <span class="f-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"></path><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg></span>
                  </div>
                </li>
                <li>1 Sesión de consultoría estratégica al mes. <span class="tooltip-icon">?<span class="tooltip-text">Llamada 1 a 1 para alinear objetivos y analizar resultados.</span></span></li>
                <li>Enlaces Inteligentes. <span class="tooltip-icon">?<span class="tooltip-text">Minisitios y enlaces ilimitados para gestionar embudos de audiencia.</span></span></li>
                <li>Gestión y diseño de campañas publicitarias. <span class="tooltip-icon">?<span class="tooltip-text">Diseñamos anuncios; las pautas son ilimitadas (presupuesto a cuenta del cliente).</span></span></li>
              </ul>
            </div>
          </div>
          <!-- CREADOR PLUS -->
          <div class="pricing-card">
            <div class="card-header">
              <h2 class="plan-name">Creador Plus</h2>
              <div class="plan-price-box">
                <div class="old-price-row"><span class="old-price">$8,000</span><span class="discount-badge">-20%</span></div>
                <div class="current-price">$6,400 <span class="price-period">/ mes</span></div>
                <div class="plus-price">Anualidad gratis <span class="tooltip-icon">?<span class="tooltip-text">Es gratis mientras sigas suscrito al plan Creador o Creador Plus.</span></span></div>
              </div>
            </div>
            <div class="card-body">
              <ul class="benefits-list">
                <li><strong>Todo lo del plan Creador, pero con más piezas:</strong></li>
                <li>Dirección creativa y postproducción de <strong>10 piezas</strong> multiformato. <span class="tooltip-icon">?<span class="tooltip-text">Inyección de contenido masivo para dominar el algoritmo.</span></span>
                  <div class="format-icons fresa-icons">
                    <span class="f-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"></polygon><rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect></svg></span>
                    <span class="f-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg></span>
                    <span class="f-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"></path><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg></span>
                  </div>
                </li>
                <li>Contenido extra a <strong>precios preferenciales</strong>. <span class="tooltip-icon">?<span class="tooltip-text">Tarifas especiales en servicios de contenido adicionales.</span></span></li>
                <li>Soporte técnico prioritario 24/7. <span class="tooltip-icon">?<span class="tooltip-text">Atención inmediata para cualquier urgencia técnica o crisis.</span></span></li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="pricing-notes">
      <div class="note-content">
        <h4>¿Es necesario contratar el paquete inicial básico?</h4>
        <p>Si ya cuentas con un sitio web, lo analizaremos a través del formulario de contacto. Si cumple con nuestros estándares técnicos de retención, <strong>gestionamos la migración sin costo</strong> y puedes saltar directamente a un Plan de Suscripción (Creador o Creador Plus). Si tu sitio requiere reestructuración desde cero, iniciaremos con el <strong>Paquete Básico ($5,000)</strong> para blindar tu infraestructura el primer mes, y a partir del segundo mes podrás suscribirte a cualquier plan de contenidos obteniendo la anualidad gratis.</p>
      </div>
    </div>

    <div class="cta-bottom-wrapper">
      <a href="/contacto" class="btn-primary">¿Te interesa? Llena el formulario</a>
    </div>
  </section>

  <Porque />
</Layout>

<style>
  .precios-container { background-color: var(--color-bg); margin-top: -120px; padding: 145px 5% 4rem 5%; display: flex; flex-direction: column; align-items: center; box-sizing: border-box; }
  .page-title { font-size: 3.5rem; font-weight: 300; line-height: 1.1; color: var(--color-text); text-align: center; margin: 0 0 1rem 0; }
  .page-subtitle { font-size: 1.15rem; font-weight: 300; color: #aaaaaa; line-height: 1.6; text-align: center; max-width: 800px; margin: 0 auto 3rem; }
  .highlight-bold { font-weight: 800; color: var(--color-accent); }
  
  .servicios-base-wrapper { width: 100%; max-width: 1000px; background-color: rgba(255, 255, 255, 0.03); border-radius: 24px; padding: 2rem; margin-bottom: 5rem; text-align: center; }
  .servicios-row { display: flex; justify-content: center; gap: 3rem; flex-wrap: wrap; }
  .base-item { display: flex; flex-direction: column; align-items: center; gap: 0.8rem; }
  .base-icon { width: 35px !important; height: 35px !important; min-width: 35px !important; display: block; object-fit: contain; }
  .base-item span { font-size: 0.85rem; color: #cccccc; text-transform: uppercase; }

  .pricing-layout { display: flex; width: 100%; max-width: 1200px; gap: 3rem; justify-content: center; flex-wrap: wrap; }
  .pricing-group-single { flex: 0 0 350px; }
  .pricing-group-double { flex: 0 0 750px; }
  .cards-row { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-top: 2rem; }
  .grid-header { text-align: center; margin-bottom: 2rem; }
  .category-title { font-size: 1.5rem; font-weight: 700; color: var(--color-text); margin: 0 0 0.5rem 0; }
  .category-desc { font-size: 0.95rem; color: #888888; margin: 0; }

  .pricing-card { background-color: var(--color-bg); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 30px; padding: 2.5rem; position: relative; display: flex; flex-direction: column; transition: all 0.3s ease; }
  .pricing-card:hover { transform: translateY(-5px); border-color: var(--color-accent); box-shadow: 0 15px 40px rgba(0, 255, 153, 0.15); }
  .featured { border-color: var(--color-accent); }
  .featured-badge { position: absolute; top: -14px; left: 50%; transform: translateX(-50%); background: var(--color-accent); color: var(--color-bg); padding: 4px 16px; border-radius: 20px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; z-index: 2; white-space: nowrap; }

  .card-header { border-bottom: 1px solid rgba(255, 255, 255, 0.1); padding-bottom: 1.5rem; margin-bottom: 1.5rem; }
  .plan-name { font-size: 2rem; font-weight: 800; color: var(--color-text); margin-bottom: 1rem; }
  .current-price { font-size: 2rem; font-weight: 800; color: #fff; }
  .price-period { font-size: 0.9rem; font-weight: 400; color: #888888; text-transform: uppercase; }
  .plus-price { color: var(--color-accent); font-weight: 600; font-size: 0.9rem; margin-top: 0.5rem; }
  
  .old-price-row { display: flex; align-items: center; gap: 10px; }
  .old-price { font-size: 1.1rem; color: #fff; text-decoration: line-through; opacity: 0.6; }
  .discount-badge { background: var(--color-accent); color: var(--color-bg); padding: 2px 8px; border-radius: 6px; font-size: 0.75rem; font-weight: 800; }
  
  .benefits-list { list-style: none; padding: 0; margin: 0; }
  .benefits-list li { font-size: 0.95rem; color: #cccccc; margin-bottom: 1rem; padding-left: 1.5rem; position: relative; }
  .benefits-list li::before { content: "•"; color: var(--color-accent); position: absolute; left: 0; }
  
  .tooltip-icon { background: rgba(255,255,255,0.15); color: #fff; border-radius: 50%; width: 18px; height: 18px; display: inline-flex; align-items: center; justify-content: center; font-size: 0.7rem; cursor: help; position: relative; }
  .tooltip-text { visibility: hidden; width: 200px; background: #222; color: #fff; padding: 8px; border-radius: 8px; position: absolute; z-index: 10; bottom: 125%; left: 50%; transform: translateX(-50%); font-size: 0.75rem; opacity: 0; transition: opacity 0.3s; }
  .tooltip-icon:hover .tooltip-text { visibility: visible; opacity: 1; }
  .fresa-icons { display: flex; gap: 8px; margin-top: 10px; }
  .f-icon { width: 32px; height: 32px; background: rgba(255,255,255,0.05); border-radius: 8px; color: var(--color-fresa); display: flex; align-items: center; justify-content: center; }
  .f-icon svg { width: 18px; height: 18px; }

  .pricing-notes { width: 100%; max-width: 1200px; margin: 3rem auto; }
  .note-content { background: rgba(255,255,255,0.02); border-left: 3px solid var(--color-accent); padding: 2rem; border-radius: 0 15px 15px 0; }
  .btn-primary { background: var(--color-accent); color: var(--color-bg); padding: 16px 36px; border-radius: 99px; text-decoration: none; font-weight: 800; display: inline-block; }
  
  @media (max-width: 1024px) {
    .pricing-layout { flex-direction: column; align-items: center; }
    .cards-row { grid-template-columns: 1fr; }
  }
</style>