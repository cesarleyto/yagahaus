---
/* src/pages/index.astro */
import Layout from '../layouts/Layout.astro';
import settings from '../data/settings.json';

const nameProyecto = settings?.title || "Inicio";
const descGeneral = settings?.description || "";
const SEOTitle = `${nameProyecto} | ${descGeneral}`;
---

<Layout title={SEOTitle} description={descGeneral}>
  <main class="page-container" style="max-width: 1200px; margin: 8rem auto 6rem; padding: 0 1.5rem; display: flex; flex-direction: column; justify-content: center; align-items: center; min-height: 50vh;">
    
    <div class="coming-soon-wrapper">
      
      <div class="icon-wrapper">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="vinyl-icon">
          <circle cx="12" cy="12" r="10"></circle>
          <circle cx="12" cy="12" r="3"></circle>
          <circle cx="12" cy="12" r="1"></circle>
          <path d="M12 2a10 10 0 0 1 10 10" opacity="0.3"></path>
        </svg>
      </div>

      <h1 class="coming-soon-text">MUY PRONTO</h1>
      
      <p class="tag-mono subtitle">Sello Musical Independiente</p>

    </div>

  </main>
</Layout>

<style>
  /* ==========================================
     ESTILOS DEL COMPONENTE "PRÓXIMAMENTE"
     ========================================== */

  .coming-soon-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    cursor: default;
    text-align: center;
    /* Un contenedor invisible para atrapar el hover desde más lejos */
    padding: 2rem;
  }

  /* --- ICONO --- */
  .icon-wrapper {
    color: var(--texto-default-color);
    transition: color 0.4s ease, transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .vinyl-icon {
    width: 90px;
    height: 90px;
    transition: transform 0.5s linear;
  }

  /* --- TEXTO --- */
  .coming-soon-text {
    font-size: clamp(3rem, 8vw, 6rem); /* Responsive automático */
    color: var(--texto-default-color);
    text-transform: uppercase;
    letter-spacing: 2px;
    margin: 0;
    line-height: 1;
    transition: all 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .subtitle {
    color: var(--texto-default-color);
    opacity: 0.5;
    transition: opacity 0.4s ease, color 0.4s ease, letter-spacing 0.4s ease;
  }

  /* ==========================================
     EFECTOS DE HOVER (La magia)
     ========================================== */

  /* El icono cambia de color, crece y el vinilo gira */
  .coming-soon-wrapper:hover .icon-wrapper {
    color: var(--color-acento);
    transform: scale(1.1);
  }
  
  .coming-soon-wrapper:hover .vinyl-icon {
    animation: spinRecord 1.5s linear infinite;
  }

  /* El texto se expande dramáticamente y se enciende con el color acento */
  .coming-soon-wrapper:hover .coming-soon-text {
    color: var(--color-acento);
    letter-spacing: 12px;
    text-shadow: 0 0 30px color-mix(in srgb, var(--color-acento) 40%, transparent);
  }

  /* El subtítulo se ilumina y se separa ligeramente */
  .coming-soon-wrapper:hover .subtitle {
    opacity: 1;
    color: var(--color-acento);
    letter-spacing: 4px;
  }

  /* Animación de giro perpetuo */
  @keyframes spinRecord {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  /* --- RESPONSIVE --- */
  @media (max-width: 768px) {
    .coming-soon-wrapper:hover .coming-soon-text {
      /* En móviles no lo expandimos tanto para que no rompa la pantalla */
      letter-spacing: 6px; 
    }
    .vinyl-icon {
      width: 70px;
      height: 70px;
    }
  }
</style>